# Copy this file to `.env` and fill in values as needed.
# For local dev, the defaults below usually work out of the box.

# ===== Frontend (Vite) =====
# Prefix for API requests the frontend makes. Leave blank to use relative paths
# which are proxied to the backend by Vite (see vite.config.ts).
# Example: http://localhost:3001
VITE_API_BASE=

# WebSocket port for Minecraft server connection (ModeratorWebSocketServer)
# MUSÍ se shodovat s plugin portem (default: 8080)
# Minecraft WS server: ws://localhost:8080
VITE_MINECRAFT_WS_PORT=8080

# ===== Backend (Node/Express) =====
# Port for the API server
PORT=3001

# Database connection (used by BOTH API and DB container init in docker-compose)
# In Docker Compose keep DB_HOST=db. For local non-docker API use 127.0.0.1.
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=solacecore

# Minecraft plugin WebSocket (the plugin usually runs on host machine)
# Must match plugin config websocket-port (default 8080)
WS_HOST=host.docker.internal
WS_PORT=8080

# ===== Docker Compose =====
TZ=Europe/Prague
HOST=0.0.0.0
WEB_PORT=8082
API_PORT=3001
PMA_HOST=db
PMA_PORT=3306

# Cache configuration (days to keep skin renders)
SKIN_TTL_DAYS=30

# Enable CORS if the frontend runs on a different origin without a proxy.
# 0 = disabled, 1 = enabled
ENABLE_CORS=0

# Optional: override path to built frontend files that the API can serve in prod
# FRONTEND_DIST=./dist

# ===== Moderator System =====
# JWT secret for moderator authentication
# IMPORTANT: Generate a secure random string for production!
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-secret-in-production-use-crypto-randomBytes
